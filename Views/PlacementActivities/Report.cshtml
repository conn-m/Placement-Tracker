@model IEnumerable<PlacementTracker.Models.PlacementActivity>

<h1>Placement Activities Report</h1>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Activity Type</th>
            <th>Description</th>
            <th>Date</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var activity in Model)
        {
            <tr>
                <td>@activity.ActivityType</td>
                <td>@activity.Description</td>
                <td>@activity.Date.ToString("d")</td>
            </tr>
        }
    </tbody>
</table>
